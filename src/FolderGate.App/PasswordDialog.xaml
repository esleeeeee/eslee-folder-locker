<Window x:Class="FolderGate.App.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Icon="pack://application:,,,/FolderGate.App;component/assets/icons/EsleeFolderLock.ico"
        Width="460"
        MinWidth="460"
        MinHeight="360"
        Loaded="PasswordDialog_Loaded">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="MessageText"
                   TextWrapping="Wrap"
                   FontSize="14"
                   MinHeight="34"
                   Margin="0,0,0,16" />

        <TextBlock Grid.Row="1"
                   Text="비밀번호"
                   Margin="0,0,0,4" />
        <PasswordBox x:Name="PasswordInput"
                     Grid.Row="2"
                     MinHeight="34"
                     VerticalContentAlignment="Center" />

        <StackPanel x:Name="ConfirmPanel"
                    Grid.Row="3"
                    Margin="0,14,0,18">
            <TextBlock Text="비밀번호 확인"
                       Margin="0,0,0,4" />
            <PasswordBox x:Name="ConfirmInput"
                         MinHeight="34"
                         VerticalContentAlignment="Center" />
        </StackPanel>

        <StackPanel x:Name="UnlockDurationPanel"
                    Grid.Row="4"
                    Margin="0,14,0,18">
            <TextBlock Text="잠금 해제 유지 시간"
                       Margin="0,0,0,4" />
            <ComboBox x:Name="UnlockDurationInput"
                      MinHeight="34"
                      VerticalContentAlignment="Center"
                      DisplayMemberPath="Label" />
        </StackPanel>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,2,0,0">
            <Button x:Name="OkButton"
                    Content="확인"
                    MinWidth="82"
                    MinHeight="34"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Ok_Click" />
            <Button x:Name="CancelButton"
                    Content="취소"
                    MinWidth="82"
                    MinHeight="34"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
